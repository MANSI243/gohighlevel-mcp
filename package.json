{
  "name": "@mastanley13/ghl-mcp-server",
  "version": "1.0.0",
  "description": "GoHighLevel MCP Server for Claude Desktop and ChatGPT integration",
  "main": "dist/hybrid-server.js",
  "bin": {
    "ghl-mcp-server": "dist/hybrid-server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/server.ts",
    "start": "node dist/hybrid-server.js",
    "start:stdio": "MCP_MODE=stdio node dist/hybrid-server.js",
    "start:http": "node dist/http-server.js",
    "start:hybrid": "node dist/hybrid-server.js",
    "start:legacy": "node dist/server.js",
    "start:legacy:http": "node dist/http-server.js",
    "postbuild": "echo 'Build completed. Checking for hybrid-server.js...' && test -f dist/hybrid-server.js && echo '✅ hybrid-server.js exists' || echo '❌ hybrid-server.js missing'",
    "vercel-build": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "gohighlevel",
    "chatgpt",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@vercel/mcp-adapter": "^0.11.1",
    "axios": "^1.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "@types/node": "^22.19.18",
    "typescript": "5.4.5",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19"
  }
}